# Copy this file to .env.local and fill in your keys.
# .env.local is git-ignored — it will never be committed.
#
#   cp .env.example .env.local
#
# Then edit .env.local with your actual values.

# === LLM API (required for benchmarks and LLM-based extraction/answering) ===
# Provider: deepseek, openai, or any OpenAI-compatible API
DEEPSEEK_API_KEY=sk-your-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com

# The scripts and library read AGENT_MEMORY_LLM_API_KEY directly,
# but fall back to $DEEPSEEK_API_KEY when it's not set.
AGENT_MEMORY_LLM_PROVIDER=openai-compatible
AGENT_MEMORY_LLM_MODEL=deepseek-chat
AGENT_MEMORY_LLM_BASE_URL=${DEEPSEEK_BASE_URL}/v1
AGENT_MEMORY_LLM_API_KEY=${DEEPSEEK_API_KEY}
AGENT_MEMORY_LLM_TIMEOUT_SECS=60

# === LLM Reranker (optional) ===
# Uncomment and set a model to enable LLM-based retrieval reranking.
# AGENT_MEMORY_RERANK_MODEL=deepseek-chat

# === Embedding (optional) ===
# Uncomment to use real embeddings via Ollama.
# AGENT_MEMORY_EMBEDDING_MODEL=all-minilm
# OLLAMA_HOST=http://127.0.0.1:11434

# === LLM Caching (optional) ===
# Uncomment to cache LLM responses to disk (speeds up repeated runs).
# AGENT_MEMORY_LLM_CACHE=runs/llm-cache.jsonl
